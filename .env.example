PORT=3000
NODE_ENV=development

DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/your_db_name
# Supabase: pooled URL (port 6543) for the app; direct URL (port 5432) for migrations
DIRECT_URL=postgresql://your_db_user:your_db_password@localhost:5432/your_db_name

JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=8h

APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173
# Public temple website origin (CORS) — e.g. https://sanwaliyasethdeoli.in
PUBLIC_WEBSITE_URL=

# Multi-tenant login: sanwaliya-seth-deoli.localhost:5173 or slug.yourdomain.com
TENANT_BASE_DOMAIN=localhost
TENANT_URL_PROTOCOL=http
ADMIN_PATH=/admin/login

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

UPLOADS_DIR=backend/uploads
