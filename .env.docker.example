# Copy to .env.docker and edit before: docker compose -f docker-compose.prod.yml --env-file .env.docker up -d --build

# PostgreSQL (runs inside Docker — no Supabase needed)
DB_USER=sansta_user
DB_PASSWORD=change_this_strong_db_password
DB_NAME=sansta_erp

# App port on your server (host:container = APP_PORT:3000)
APP_PORT=3000

# Auth — change before production
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=8h

# Public URLs (use your real domain in production)
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
PUBLIC_URL=http://localhost:3000

# Multi-tenant admin login
TENANT_BASE_DOMAIN=localhost
TENANT_URL_PROTOCOL=http
ADMIN_PATH=/admin/login

# Set true only on first deploy to create admin users + sample trust, then set back to false
SEED_DATABASE=true
